/dts-v1/;
/plugin/;

#include "imx8mp-pinfunc.h"
#include <dt-bindings/clock/imx8mp-clock.h>
#include <dt-bindings/gpio/gpio.h>

&{/} {
    reg_ov5640_avdd: regulator-ov5640-avdd {
        compatible = "regulator-fixed";
        regulator-name = "ov5640_avdd";
        regulator-min-microvolt = <2800000>;
        regulator-max-microvolt = <2800000>;
        regulator-always-on;
    };

    reg_ov5640_dovdd: regulator-ov5640-dovdd {
        compatible = "regulator-fixed";
        regulator-name = "ov5640_dovdd";
        regulator-min-microvolt = <1800000>;
        regulator-max-microvolt = <1800000>;
        regulator-always-on;
    };

    reg_ov5640_dvdd: regulator-ov5640-dvdd {
        compatible = "regulator-fixed";
        regulator-name = "ov5640_dvdd";
        regulator-min-microvolt = <1500000>;
        regulator-max-microvolt = <1500000>;
        regulator-always-on;
    };
};

&mipi_csi_0 {
    status = "okay";
    /delete-node/ port;

    port@0 {
        mipi_csi0_from_ov5640_ep: endpoint {
            remote-endpoint = <&ov5640_to_mipi_ep>;
            data-lanes = <2>;
            csis-hs-settle = <13>;
        };
    };
};

&i2c3 {
    #address-cells = <1>;
    #size-cells = <0>;
    status = "okay";

    ov5640: ov5640@3c {
        status = "okay";
        compatible = "ovti,ov5640";
        reg = <0x3c>;
        pinctrl-names = "default";
        pinctrl-0 = <&pinctrl_ov5640_gpios &pinctrl_ov5640_mclk>;
        AVDD-supply = <&reg_ov5640_avdd>;
        DOVDD-supply = <&reg_ov5640_dovdd>;
        DVDD-supply = <&reg_ov5640_dvdd>;
        clocks = <&clk IMX8MP_CLK_IPP_DO_CLKO2>;
        clock-names = "xclk";
        assigned-clocks = <&clk IMX8MP_CLK_IPP_DO_CLKO2>;
        assigned-clock-parents = <&clk IMX8MP_CLK_24M>;
        assigned-clock-rates = <24000000>;
        csi_id = <0>;
        powerdown-gpios = <&gpio4 8 GPIO_ACTIVE_HIGH>;
        reset-gpios = <&gpio4 9 GPIO_ACTIVE_LOW>;
        mclk = <24000000>;
        mclk_source = <0>;
        mipi_csi;

        port {
            ov5640_to_mipi_ep: endpoint {
                remote-endpoint = <&mipi_csi0_from_ov5640_ep>;
                data-lanes = <1 2>;
                clock-lanes = <0>;
            };
        };
    };
};

/* Media Controller */
&{/soc@0/bus@32c00000/camera} {
    status = "okay";
};

&isi_0 {
    status = "okay";
    cap_device { status = "okay"; };
    m2m_device { status = "okay"; };
};

&isp_0 { 
    status = "okay"; 
};

&dewarp { 
    status = "okay"; 
};

&iomuxc {

    /delete-property/ pinctrl-0;

    pinctrl-0 = <&pinctrl_gpio1>, <&pinctrl_gpio2>,
		    <&pinctrl_gpio3>, <&pinctrl_gpio4>,
		    <&pinctrl_gpio7>, <&pinctrl_gpio8>,
		    <&pinctrl_gpio_hog2>, <&pinctrl_gpio_hog4>,
		    <&pinctrl_hdmi_hog>;

    /delete-node/ gpiohog3grp;

    pinctrl_ov5640_gpios: ov5640gpiosgrp {
        fsl,pins = <
            MX8MP_IOMUXC_SAI1_RXD6__GPIO4_IO08    0x106 
            MX8MP_IOMUXC_SAI1_RXD7__GPIO4_IO09    0x106
        >;
    };

    pinctrl_ov5640_mclk: ov5640mclkgrp {
        fsl,pins = <
            MX8MP_IOMUXC_GPIO1_IO15__CCM_CLKO2    0x156
        >;
    };
};

&fec {
    status = "disabled";
};
