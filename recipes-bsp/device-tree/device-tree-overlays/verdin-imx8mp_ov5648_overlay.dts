/dts-v1/;
/plugin/;

#include "imx8mp-pinfunc.h"
#include <dt-bindings/clock/imx8mp-clock.h>
#include <dt-bindings/gpio/gpio.h>

&{/} {
    /* 
     * Khai báo các bộ quản lý nguồn (Regulators) chuẩn chỉ 
     * để Driver camera nhận diện và làm sạch log dmesg.
     */
    reg_ov5648_avdd: regulator-ov5648-avdd {
        compatible = "regulator-fixed";
        regulator-name = "ov5648_avdd";
        regulator-min-microvolt = <2800000>;
        regulator-max-microvolt = <2800000>;
        regulator-always-on;
    };

    reg_ov5648_dovdd: regulator-ov5648-dovdd {
        compatible = "regulator-fixed";
        regulator-name = "ov5648_dovdd";
        regulator-min-microvolt = <1800000>;
        regulator-max-microvolt = <1800000>;
        regulator-always-on;
    };

    reg_ov5648_dvdd: regulator-ov5648-dvdd {
        compatible = "regulator-fixed";
        regulator-name = "ov5648_dvdd";
        regulator-min-microvolt = <1500000>;
        regulator-max-microvolt = <1500000>;
        regulator-always-on;
    };
};

/* Verdin I2C_4_CSI (SODIMM 93, 95) */
&i2c3 {
    #address-cells = <1>;
    #size-cells = <0>;
    status = "okay";

    ov5648: camera@36 {
        compatible = "ovti,ov5648";
        reg = <0x36>;
        pinctrl-names = "default";
        pinctrl-0 = <&pinctrl_ov5648_gpios>;
        
        /* Kết nối nguồn chuẩn chỉ theo Binding YAML */
        avdd-supply = <&reg_ov5648_avdd>;
        dovdd-supply = <&reg_ov5648_dovdd>;
        dvdd-supply = <&reg_ov5648_dvdd>;

        /* Cung cấp xung nhịp Master Clock cho Camera */
        clocks = <&clk IMX8MP_CLK_IPP_DO_CLKO1>;
        clock-names = "xclk";
        assigned-clocks = <&clk IMX8MP_CLK_IPP_DO_CLKO1>;
        assigned-clock-parents = <&clk IMX8MP_SYS_PLL2_50M>;
        assigned-clock-rates = <24000000>;

        /* GPIO điều khiển nguồn và reset */
        powerdown-gpios = <&gpio4 8 GPIO_ACTIVE_LOW>;
        reset-gpios = <&gpio4 9 GPIO_ACTIVE_LOW>;

        status = "okay";

        port {
            ov5648_to_mipi_ep: endpoint {
                remote-endpoint = <&mipi_csi0_from_ov5648_ep>;
                data-lanes = <1 2>;
                link-frequencies = /bits/ 64 <210000000 168000000>;
            };
        };
    };
};

/* MIPI CSI-2 Receiver Pipeline */
/* Khắc phục lỗi "No remote pad found" bằng cách nối tường minh CSI -> ISI */
&mipi_csi_0 {
    status = "okay";
    ports {
        #address-cells = <1>;
        #size-cells = <0>;
        port@0 {
            reg = <0>;
            mipi_csi0_from_ov5648_ep: endpoint {
                remote-endpoint = <&ov5648_to_mipi_ep>;
                data-lanes = <1 2>;
            };
        };
        port@1 {
            reg = <1>;
            mipi_csi0_to_isi_0_ep: endpoint {
                remote-endpoint = <&isi_0_from_mipi_csi0_ep>;
            };
        };
    };
};

/* Media Controller Framework Registration */
&cameradev {
    status = "okay";
};

/* ISI (Image Sensor Interface) Processor */
&isi_0 {
    status = "okay";
    cap_device {
        status = "okay";
    };
    ports {
        #address-cells = <1>;
        #size-cells = <0>;
        port@0 {
            reg = <0>;
            isi_0_from_mipi_csi0_ep: endpoint {
                remote-endpoint = <&mipi_csi0_to_isi_0_ep>;
            };
        };
    };
};
/* Vô hiệu hóa Ethernet 2 để lấy chân GPIO */
&fec {
    status = "disabled";
};

/* Thiết lập Pin Muxing cho GPIO */
&iomuxc {
    pinctrl_ov5648_gpios: ov5648gpiosgrp {
        fsl,pins = <
            MX8MP_IOMUXC_SAI1_RXD6__GPIO4_IO08    0x10 /* Powerdown */
            MX8MP_IOMUXC_SAI1_RXD7__GPIO4_IO09    0x10 /* Reset */
        >;
    };
};
